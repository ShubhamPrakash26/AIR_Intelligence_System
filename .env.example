# AIR Clinical Incident Intelligence Engine Configuration

# Application Settings
DEBUG=false
APP_NAME="AIR Clinical Incident Intelligence Engine"
APP_VERSION="1.0.0"

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# LLM Configuration (Anthropic / Claude)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
LLM_MODEL=claude-sonnet-4-6
TEMPERATURE=0.7
MAX_TOKENS=2000

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32

# Vector Store Configuration (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=incidents

# Data Paths
DATA_DIR=./data
INPUT_DIR=./data/input
OUTPUT_DIR=./data/processed
EMBEDDINGS_DIR=./data/embeddings

# Processing Configuration
BATCH_SIZE=32
NUM_WORKERS=4

# Validation Configuration
CONFIDENCE_THRESHOLD=0.7
VALIDATION_RETRIES=3

# Clustering Configuration
CLUSTERING_ALGORITHM=hdbscan
MIN_CLUSTER_SIZE=5
MIN_SAMPLES=5
